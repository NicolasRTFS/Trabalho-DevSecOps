APP_NAME=AcervoHub
ENVIRONMENT=development
SECRET_KEY=change-this-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
PASSWORD_HASH_ROUNDS=12
DATABASE_URL=postgresql+psycopg://acervo_user:acervo_password@postgres:5432/acervo_hub
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SEED_DATABASE=true
POSTGRES_DB=acervo_hub
POSTGRES_USER=acervo_user
POSTGRES_PASSWORD=acervo_password
